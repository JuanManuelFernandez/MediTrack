<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AgregarMedicamento">

    <EditText
        android:id="@+id/txt_medicamento"
        android:layout_width="179dp"
        android:layout_height="43dp"
        android:ems="10"
        android:hint="Medicamento"
        android:inputType="text"
        android:textColor="?attr/colorEditText"
        android:text=""
        android:textColorHint="?attr/colorHintEditText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.13"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/txt_cantidad"
        android:layout_width="106dp"
        android:layout_height="41dp"
        android:ems="10"
        android:hint="Cantidad"
        android:inputType="number"
        android:textColor="?attr/colorEditText"
        android:text="@string/Cantidad"
        android:textColorHint="?attr/colorHintEditText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.38"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.228"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/txt_horario"
        android:layout_width="164dp"
        android:layout_height="38dp"
        android:ems="10"
        android:hint="Intervalo horario"
        android:inputType="number"
        android:text="@string/Horario"
        android:textColor="?attr/colorEditText"
        android:textColorHint="?attr/colorHintEditText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.469"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.324"
        tools:ignore="MissingConstraints" />

    <Button
        android:id="@+id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/rojo"
        android:onClick="Btn_Volver"
        android:text="@string/BotonVolver"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.312"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.569"
        tools:ignore="MissingConstraints" />

    <Button
        android:id="@+id/button3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/green_light"
        android:onClick="Btn_Agregar"
        android:text="@string/Agregar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.711"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.569"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/txt_dosis"
        android:layout_width="134dp"
        android:layout_height="40dp"
        android:ems="10"
        android:hint="Dosis"
        android:inputType="number"
        android:textColor="?attr/colorEditText"
        android:text="@string/Horario"
        android:textColorHint="?attr/colorHintEditText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.418"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.429"
        tools:ignore="MissingConstraints" />
</androidx.constraintlayout.widget.ConstraintLayout>