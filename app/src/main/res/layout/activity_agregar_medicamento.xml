<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AgregarMedicamento">

    <EditText
        android:id="@+id/txt_medicamento"
        android:layout_width="179dp"
        android:layout_height="43dp"
        android:ems="10"
        android:hint="Medicamento"
        android:inputType="text"
        android:textColor="?attr/colorEditText"
        android:text=""
        android:textColorHint="?attr/colorHintEditText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.13"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/txt_cantidad"
        android:layout_width="106dp"
        android:layout_height="41dp"
        android:ems="10"
        android:hint="Cantidad"
        android:inputType="number"
        android:textColor="?attr/colorEditText"
        android:text="@string/Cantidad"
        android:textColorHint="?attr/colorHintEditText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.38"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.228"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/txt_horario"
        android:layout_width="164dp"
        android:layout_height="38dp"
        android:ems="10"
        android:hint="Intervalo horario"
        android:inputType="number"
        android:text="@string/Horario"
        android:textColor="?attr/colorEditText"
        android:textColorHint="?attr/colorHintEditText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.469"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.324"
        tools:ignore="MissingConstraints" />

    <ImageButton
        android:id="@+id/btnVolver"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:onClick="Btn_Volver"
        android:padding="8dp"
        android:src="@drawable/volver"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="16dp" />

    <ImageButton
        android:id="@+id/btnAgregar"
        android:layout_width="73dp"
        android:layout_height="62dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:onClick="Btn_Agregar"
        android:padding="8dp"
        android:src="@drawable/confirmar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.461"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.517"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/txt_dosis"
        android:layout_width="134dp"
        android:layout_height="40dp"
        android:ems="10"
        android:hint="Dosis"
        android:inputType="number"
        android:textColor="?attr/colorEditText"
        android:text="@string/Horario"
        android:textColorHint="?attr/colorHintEditText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.418"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.429"
        tools:ignore="MissingConstraints" />
</androidx.constraintlayout.widget.ConstraintLayout>